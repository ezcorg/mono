---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import { Clipboard, Check } from "lucide-astro";
---

<Layout title="codeblock | ez co" description="An interactive demo of the @joinezco/codeblock component.">
	<section>
		<div class="w-full mx-auto flex flex-col gap-8">
			<Navbar currentPath="/work" />

			<button class="install-cmd" data-cmd="npm install @joinezco/codeblock">
				<span class="icon-copy"><Clipboard size={14} /></span>
				<span class="icon-check"><Check size={14} /></span>
				<code>npm install @joinezco/codeblock</code>
			</button>

			<div class="demo-container border-2 border-[#333333] overflow-hidden">
				<div id="codeblock-mount">
					<div class="loading-indicator"><div class="loading-bar"></div></div>
				</div>
			</div>
		</div>
	</section>

	<Footer slot="footer" />

	<script>
		import { CodeblockFS } from "@joinezco/codeblock";
		import { files } from "../data/work.js";

		async function init() {
			const fs = await CodeblockFS.fsa("ezco-demo");

			// Seed files only if example.ts doesn't exist yet (first visit)
			const exists = await fs.exists("example.ts");
			if (!exists) {
				await Promise.all(
					files.map(async ([path, content]) => {
						await fs.writeFile(path, content);
					}),
				);
			}

			const { createCodeblock, SearchIndex } = await import(
				"@joinezco/codeblock"
			);
			const container = document.getElementById("codeblock-mount")!;
			container.innerHTML = '';
			const index = await SearchIndex.get(fs, ".codeblock/index.json");

			createCodeblock({
				parent: container,
				fs,
				filepath: "example.ts",
				index,
				cwd: "/",
				dark: true,
			});
		}

		init().catch(console.error);

		document.querySelector('.install-cmd')?.addEventListener('click', async (e) => {
			const btn = (e.currentTarget as HTMLElement);
			await navigator.clipboard.writeText(btn.dataset.cmd!);
			btn.classList.add('copied');
			setTimeout(() => btn.classList.remove('copied'), 1500);
		});
	</script>

	<style>
		.install-cmd {
			font-family: monospace;
			font-size: 0.875rem;
			color: #F5F5F5;
			opacity: 0.6;
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			background: none;
			border: 2px solid #333333;
			padding: 0.5rem 0.75rem;
			cursor: pointer;
			transition: opacity 0.15s;
		}

		.install-cmd:hover {
			opacity: 1;
		}

		.icon-check {
			display: none;
		}

		.install-cmd.copied .icon-copy {
			display: none;
		}

		.install-cmd.copied .icon-check {
			display: inline-flex;
		}

		.demo-container {
			width: 100%;
			min-height: 70vh;
			display: flex;
			flex-direction: column;
		}

		#codeblock-mount {
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		#codeblock-mount :global(.cm-editor) {
			flex: 1;
		}

		.loading-indicator {
			display: flex;
			align-items: center;
			justify-content: center;
			flex: 1;
			min-height: 200px;
		}

		.loading-bar {
			width: 48px;
			height: 2px;
			background: #444;
			border-radius: 1px;
			animation: loading-pulse 1.5s ease-in-out infinite;
		}

		@keyframes loading-pulse {
			0%, 100% { opacity: 0.3; }
			50% { opacity: 1; }
		}
	</style>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout title="codeblock | ez co" description="An interactive demo of the @joinezco/codeblock component.">
	<section>
		<div class="w-full mx-auto flex flex-col gap-8">
			<Navbar currentPath="/work" />

			<div class="demo-container border-2 border-[#333333] overflow-hidden">
				<div id="codeblock-mount"></div>
			</div>
		</div>
	</section>

	<Footer slot="footer" />

	<script>
		import { CodeblockFS } from "@joinezco/codeblock";
		import { files } from "../data/work.js";

		async function init() {
			const fs = await CodeblockFS.worker();
			await Promise.all(
				files.map(async ([path, content]) => {
					await fs.writeFile(path, content);
				}),
			);

			const { createCodeblock, SearchIndex } = await import(
				"@joinezco/codeblock"
			);
			const container = document.getElementById("codeblock-mount")!;
			const index = await SearchIndex.get(fs, ".codeblock/index.json");

			// Pass content directly to avoid VFS readFile timing issues
			const exampleFile = files.find(([p]) => p === "example.ts");
			createCodeblock({
				parent: container,
				fs,
				content: exampleFile ? exampleFile[1] : "",
				language: "ts",
				index,
				cwd: "/",
				dark: true,
			});
		}

		init().catch(console.error);
	</script>

	<style>
		.demo-container {
			min-height: 70vh;
			display: flex;
			flex-direction: column;
		}

		#codeblock-mount {
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		#codeblock-mount :global(.cm-editor) {
			flex: 1;
		}
	</style>
</Layout>

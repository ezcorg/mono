---
import DualColumnLayout from "../../layouts/DualColumnLayout.astro";
import Footer from "../../components/Footer.astro";
---

<DualColumnLayout title="codeblock | ez co" description="An interactive demo of the @joinezco/codeblock component." currentPath="/work">
		<div class="install-container overflow-hidden">
			<div id="install-mount"></div>
		</div>
		<div class="demo-container overflow-hidden">
			<div id="codeblock-mount">
				<div class="loading-indicator"><div class="loading-bar"></div></div>
			</div>
		</div>

	<Footer slot="footer" />

	<script>
		import { getDemoFs } from "../../scripts/demo-fs";
		import { slideInDemo } from "../../scripts/demo-anim";

		let installView: any = null;
		let mainView: any = null;

		async function mount() {
			const installMount = document.getElementById("install-mount");
			const container = document.getElementById("codeblock-mount");
			if (!installMount || !container) return;

			if (installView) {
				try { installView.destroy(); } catch {}
				installView = null;
			}
			if (mainView) {
				try { mainView.destroy(); } catch {}
				mainView = null;
			}

			const { createCodeblock, SearchIndex } = await import("@joinezco/codeblock");

			const fs = await getDemoFs();
			installMount.innerHTML = '';
			installView = createCodeblock({
				parent: installMount,
				fs,
				filepath: "install.codeblock.sh",
				cwd: "/",
				dark: true,
				toolbar: false,
			});
			slideInDemo(installMount);

			container.innerHTML = '';
			const index = await SearchIndex.get(fs, ".codeblock/index.json");
			mainView = createCodeblock({
				parent: container,
				fs,
				filepath: "example.ts",
				index,
				cwd: "/",
				dark: true,
			});
			slideInDemo(container);
		}

		mount().catch(console.error);
		document.addEventListener("astro:page-load", () => {
			if (location.pathname.replace(/\/$/, "") === "/work/codeblock") {
				mount().catch(console.error);
			}
		});
		document.addEventListener("astro:before-swap", () => {
			if (installView) {
				try { installView.destroy(); } catch {}
				installView = null;
			}
			if (mainView) {
				try { mainView.destroy(); } catch {}
				mainView = null;
			}
		});
	</script>

	<style>
		.install-container {
			width: 100%;
			display: flex;
			flex-direction: column;
		}

		#install-mount {
			display: flex;
			flex-direction: column;
		}

		#install-mount :global(.cm-editor) {
			min-height: 0;
		}

		/* `view-transition-name` is set inline only on exit (see
		   Layout.astro's `astro:before-preparation` handler) — see the
		   markdown-editor page for the rationale. */

		.demo-container {
			width: 100%;
			min-height: 70vh;
			display: flex;
			flex-direction: column;
		}

		#codeblock-mount {
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		#codeblock-mount :global(.cm-editor) {
			flex: 1;
		}

		/* Override codeblock CSS variables to make the editor transparent.
		   Needs higher specificity than the package's
		   `[data-theme="dark"] .cm-editor` selector (0,2,0); the scoped
		   `#codeblock-mount` adds an attribute selector to bring us to 1,3,0. */
		#install-mount :global([data-theme="dark"] .cm-editor),
		#install-mount :global(.cm-editor[data-theme="dark"]),
		#codeblock-mount :global([data-theme="dark"] .cm-editor),
		#codeblock-mount :global(.cm-editor[data-theme="dark"]),
		#codeblock-mount :global([data-theme="dark"] .cm-toolbar-panel),
		#codeblock-mount :global(.cm-toolbar-panel[data-theme="dark"]) {
			--cm-background: transparent;
			/* Gutter stays solid black so line numbers don't clash with
			   horizontally-scrolled code text underneath. */
			--cm-gutter-background: #000000;
			--cm-line-highlight: transparent;
			--cm-toolbar-bg-dark: transparent;
			--cm-toolbar-bg-light: transparent;
			--cm-toolbar-background: transparent;
		}

		/* CodeMirror's baseTheme draws a focus outline on `.cm-editor.cm-focused`
		   and a default background on `.cm-panels`/`.cm-panel`. Suppress both. */
		#install-mount :global(.cm-editor.cm-focused),
		#codeblock-mount :global(.cm-editor.cm-focused) {
			outline: none;
		}
		#install-mount :global(.cm-panels),
		#install-mount :global(.cm-panel),
		#codeblock-mount :global(.cm-panels),
		#codeblock-mount :global(.cm-panel) {
			background: transparent;
		}

		/* Tooltips and the search-results dropdown render inside the
		   `.cm-editor`, so a scoped descendant selector is enough. They
		   read `--cm-toolbar-background` (transparent here), so override
		   the background directly. */
		#codeblock-mount :global(.cm-tooltip),
		#codeblock-mount :global(.cm-search-results) {
			background: #000000;
		}

		/* The right-click context menu is appended to `document.body`,
		   outside `#codeblock-mount`, so it needs a fully-global selector.
		   It copies `data-theme` from the editor onto itself. */
		:global(.cm-context-menu[data-theme="dark"]) {
			background: #000000;
		}

		.loading-indicator {
			display: flex;
			align-items: center;
			justify-content: center;
			flex: 1;
			min-height: 200px;
		}

		.loading-bar {
			width: 48px;
			height: 2px;
			background: #444;
			border-radius: 1px;
			animation: loading-pulse 1.5s ease-in-out infinite;
		}

		@keyframes loading-pulse {
			0%, 100% { opacity: 0.3; }
			50% { opacity: 1; }
		}
	</style>
</DualColumnLayout>

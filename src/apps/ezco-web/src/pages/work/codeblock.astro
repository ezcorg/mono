---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout title="codeblock | ez co" description="An interactive demo of the @joinezco/codeblock component.">
	<section>
		<div class="w-full mx-auto flex flex-col gap-8">
			<Navbar currentPath="/work" />

			<div class="demo-container overflow-hidden">
				<div id="codeblock-mount">
					<div class="loading-indicator"><div class="loading-bar"></div></div>
				</div>
			</div>
		</div>
	</section>

	<Footer slot="footer" />

	<script>
		import { CodeblockFS } from "@joinezco/codeblock";
		import { files } from "../data/work.js";

		async function init() {
			const fs = await CodeblockFS.worker(undefined, "ezco-demo");

			// Seed demo files — always write if content is empty or missing
			await Promise.all(
				files.map(async ([path, content]) => {
					try {
						const existing = await fs.exists(path);
						if (!existing) {
							await fs.writeFile(path, content);
						} else {
							const current = await fs.readFile(path);
							if (!current || current.length === 0) {
								await fs.writeFile(path, content);
							}
						}
					} catch {
						await fs.writeFile(path, content);
					}
				}),
			);

			const { createCodeblock, SearchIndex } = await import(
				"@joinezco/codeblock"
			);
			const container = document.getElementById("codeblock-mount")!;
			container.innerHTML = '';
			const index = await SearchIndex.get(fs, ".codeblock/index.json");

			createCodeblock({
				parent: container,
				fs,
				filepath: "example.ts",
				index,
				cwd: "/",
				dark: true,
			});
		}

		init().catch(console.error);
	</script>

	<style>
		.demo-container {
			width: 100%;
			min-height: 70vh;
			display: flex;
			flex-direction: column;
		}

		#codeblock-mount {
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		#codeblock-mount :global(.cm-editor) {
			flex: 1;
		}

		/* Override codeblock CSS variables to make the editor transparent.
		   Needs higher specificity than the package's
		   `[data-theme="dark"] .cm-editor` selector (0,2,0); the scoped
		   `#codeblock-mount` adds an attribute selector to bring us to 1,3,0. */
		#codeblock-mount :global([data-theme="dark"] .cm-editor),
		#codeblock-mount :global(.cm-editor[data-theme="dark"]),
		#codeblock-mount :global([data-theme="dark"] .cm-toolbar-panel),
		#codeblock-mount :global(.cm-toolbar-panel[data-theme="dark"]) {
			--cm-background: transparent;
			/* Gutter stays solid black so line numbers don't clash with
			   horizontally-scrolled code text underneath. */
			--cm-gutter-background: #000000;
			--cm-line-highlight: transparent;
			--cm-toolbar-bg-dark: transparent;
			--cm-toolbar-bg-light: transparent;
			--cm-toolbar-background: transparent;
		}

		/* CodeMirror's baseTheme draws a focus outline on `.cm-editor.cm-focused`
		   and a default background on `.cm-panels`/`.cm-panel`. Suppress both. */
		#codeblock-mount :global(.cm-editor.cm-focused) {
			outline: none;
		}
		#codeblock-mount :global(.cm-panels),
		#codeblock-mount :global(.cm-panel) {
			background: transparent;
		}

		/* Tooltips and the search-results dropdown render inside the
		   `.cm-editor`, so a scoped descendant selector is enough. They
		   read `--cm-toolbar-background` (transparent here), so override
		   the background directly. */
		#codeblock-mount :global(.cm-tooltip),
		#codeblock-mount :global(.cm-search-results) {
			background: #000000;
		}

		/* The right-click context menu is appended to `document.body`,
		   outside `#codeblock-mount`, so it needs a fully-global selector.
		   It copies `data-theme` from the editor onto itself. */
		:global(.cm-context-menu[data-theme="dark"]) {
			background: #000000;
		}

		.loading-indicator {
			display: flex;
			align-items: center;
			justify-content: center;
			flex: 1;
			min-height: 200px;
		}

		.loading-bar {
			width: 48px;
			height: 2px;
			background: #444;
			border-radius: 1px;
			animation: loading-pulse 1.5s ease-in-out infinite;
		}

		@keyframes loading-pulse {
			0%, 100% { opacity: 0.3; }
			50% { opacity: 1; }
		}
	</style>
</Layout>

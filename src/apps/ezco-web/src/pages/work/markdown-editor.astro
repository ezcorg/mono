---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
---

<Layout title="markdown-editor | ez co" description="An interactive demo of the @joinezco/markdown-editor component.">
	<section>
		<div class="w-full mx-auto flex flex-col gap-8">
			<Navbar currentPath="/work" />

			<div class="demo-container border-2 border-[#333333] overflow-hidden">
				<div id="editor-mount"></div>
			</div>
		</div>
	</section>

	<Footer slot="footer" />

	<script>
		import { CodeblockFS } from "@joinezco/codeblock";
		import { files } from "../data/work.js";

		async function init() {
			const fs = await CodeblockFS.fsa("ezco-mde-demo");

			// Seed files only if hello.md doesn't exist yet (first visit)
			const exists = await fs.exists("hello.md");
			if (!exists) {
				await Promise.all(
					files.map(async ([path, content]) => {
						await fs.writeFile(path, content);
					}),
				);
			}

			const { createEditor } = await import("@joinezco/markdown-editor");
			const container = document.getElementById("editor-mount")!;

			const editor = createEditor({
				element: container,
				autofocus: false,
				fs: {
					fs,
					filepath: "hello.md",
				},
			});
			editor.view.dom.setAttribute("data-theme", "dark");
		}

		init().catch(console.error);
	</script>

	<style>
		.demo-container {
			min-height: 70vh;
			display: flex;
			flex-direction: column;
		}

		#editor-mount {
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		#editor-mount :global(.ezco-mde) {
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		#editor-mount :global(.ProseMirror) {
			flex: 1;
		}

		/* Tighten margins for embedded components */
		#editor-mount :global(.cm-editor) {
			margin: 1rem 0;
		}
		#editor-mount :global(table) {
			margin: 1rem 0;
		}
	</style>
</Layout>

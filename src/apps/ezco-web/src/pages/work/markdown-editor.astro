---
import Layout from "../../layouts/Layout.astro";
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import { Clipboard, Check } from "lucide-astro";
---

<Layout title="markdown-editor | ez co" description="An interactive demo of the @joinezco/markdown-editor component.">
	<section>
		<div class="w-full mx-auto flex flex-col gap-8">
			<Navbar currentPath="/work" />

			<button class="install-cmd" data-cmd="npm install @joinezco/markdown-editor">
				<span class="icon-copy"><Clipboard size={14} /></span>
				<span class="icon-check"><Check size={14} /></span>
				<code>npm install @joinezco/markdown-editor</code>
			</button>

			<div class="demo-container bg-[#1e1e1e] border-2 border-[#333333] overflow-hidden">
				<div id="editor-mount">
					<div class="loading-indicator"><div class="loading-bar"></div></div>
				</div>
			</div>
		</div>
	</section>

	<Footer slot="footer" />

	<script>
		import { CodeblockFS } from "@joinezco/codeblock";
		import { files } from "../data/work.js";

		async function init() {
			const fs = await CodeblockFS.fsa("ezco-demo");

			// Seed files only if hello.md doesn't exist yet (first visit)
			const exists = await fs.exists("hello.md");
			if (!exists) {
				await Promise.all(
					files.map(async ([path, content]) => {
						await fs.writeFile(path, content);
					}),
				);
			}

			const { createEditor } = await import("@joinezco/markdown-editor");
			const container = document.getElementById("editor-mount")!;
			container.innerHTML = '';

			const editor = createEditor({
				element: container,
				autofocus: false,
				fs: {
					fs,
					filepath: "hello.md",
				},
			});
			editor.view.dom.setAttribute("data-theme", "dark");
		}

		init().catch(console.error);

		document.querySelector('.install-cmd')?.addEventListener('click', async (e) => {
			const btn = (e.currentTarget as HTMLElement);
			await navigator.clipboard.writeText(btn.dataset.cmd!);
			btn.classList.add('copied');
			setTimeout(() => btn.classList.remove('copied'), 1500);
		});
	</script>

	<style>
		.install-cmd {
			font-family: monospace;
			font-size: 0.875rem;
			color: #F5F5F5;
			opacity: 0.6;
			display: inline-flex;
			align-items: center;
			gap: 0.5rem;
			background: none;
			border: 2px solid #333333;
			padding: 0.5rem 0.75rem;
			cursor: pointer;
			transition: opacity 0.15s;
		}

		.install-cmd:hover {
			opacity: 1;
		}

		.icon-check {
			display: none;
		}

		.install-cmd.copied .icon-copy {
			display: none;
		}

		.install-cmd.copied .icon-check {
			display: inline-flex;
		}

		.demo-container {
			min-height: 70vh;
			display: flex;
			flex-direction: column;
		}

		#editor-mount {
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		#editor-mount :global(.ezco-mde) {
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		#editor-mount :global(.ProseMirror) {
			flex: 1;
		}

		/* Tighten margins for embedded components */
		#editor-mount :global(.cm-editor) {
			margin: 1rem 0;
		}
		#editor-mount :global(table) {
			margin: 1rem 0;
		}

		.loading-indicator {
			display: flex;
			align-items: center;
			justify-content: center;
			flex: 1;
			min-height: 200px;
		}

		.loading-bar {
			width: 48px;
			height: 2px;
			background: #444;
			border-radius: 1px;
			animation: loading-pulse 1.5s ease-in-out infinite;
		}

		@keyframes loading-pulse {
			0%, 100% { opacity: 0.3; }
			50% { opacity: 1; }
		}
	</style>
</Layout>

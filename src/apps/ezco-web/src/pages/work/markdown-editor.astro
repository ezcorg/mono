---
import DualColumnLayout from "../../layouts/DualColumnLayout.astro";
import Footer from "../../components/Footer.astro";
---

<DualColumnLayout title="markdown-editor | ez co" description="An interactive demo of the @joinezco/markdown-editor component." currentPath="/work">
		<div class="demo-container bg-[#1e1e1e]">
			<div id="editor-mount">
				<div class="loading-indicator"><div class="loading-bar"></div></div>
			</div>
		</div>

	<Footer slot="footer" />

	<script>
		import { getDemoFs } from "../../scripts/demo-fs";
		import { slideInDemo } from "../../scripts/demo-anim";

		let editor: any = null;

		async function mount() {
			const container = document.getElementById("editor-mount");
			if (!container) return;
			// If a previous editor instance is still attached, tear it down
			// (CodeMirror inside ExtendedCodeblock may hold view references).
			if (editor) {
				try { editor.destroy(); } catch {}
				editor = null;
			}
			container.innerHTML = '<div class="loading-indicator"><div class="loading-bar"></div></div>';

			const fs = await getDemoFs();
			const { createEditor } = await import("@joinezco/markdown-editor");
			container.innerHTML = '';
			editor = createEditor({
				element: container,
				autofocus: false,
				fs: {
					fs,
					filepath: "hello.md",
				},
				toolbar: {},
			});
			editor.view.dom.setAttribute("data-theme", "dark");
			slideInDemo(container);
		}

		mount().catch(console.error);
		document.addEventListener("astro:page-load", () => {
			if (location.pathname.replace(/\/$/, "") === "/work/markdown-editor") {
				mount().catch(console.error);
			}
		});
		document.addEventListener("astro:before-swap", () => {
			if (editor) {
				try { editor.destroy(); } catch {}
				editor = null;
			}
		});
	</script>

	<style>
		@font-face {
			font-family: "Source Serif 4";
			src: url("/fonts/Source_Serif_4/SourceSerif4-VariableFont_opsz,wght.ttf") format("truetype-variations");
			font-weight: 200 900;
			font-style: normal;
		}

		@font-face {
			font-family: "Source Serif 4";
			src: url("/fonts/Source_Serif_4/SourceSerif4-Italic-VariableFont_opsz,wght.ttf") format("truetype-variations");
			font-weight: 200 900;
			font-style: italic;
		}

		#editor-mount :global(.ProseMirror) {
			font-family: 'Source Serif 4', system-ui, Avenir, Helvetica, Arial, serif;
		}

		/* Override codeblock CSS variables to make embedded code editors
		   transparent. Needs higher specificity than the package's
		   `[data-theme="dark"] .cm-editor` selector (0,2,0); the scoped
		   `#editor-mount` adds an attribute selector to bring us to 1,3,0. */
		#editor-mount :global([data-theme="dark"] .cm-editor),
		#editor-mount :global(.cm-editor[data-theme="dark"]),
		#editor-mount :global([data-theme="dark"] .cm-toolbar-panel),
		#editor-mount :global(.cm-toolbar-panel[data-theme="dark"]) {
			--cm-background: transparent;
			/* Gutter stays solid black so line numbers don't clash with
			   horizontally-scrolled code text underneath. */
			--cm-gutter-background: #000000;
			--cm-line-highlight: transparent;
			/* Toolbar background stays solid black so it doesn't go
			   transparent when stuck to the top of a scrolling
			   codeblock. */
			--cm-toolbar-bg-dark: #000000;
			--cm-toolbar-bg-light: #000000;
			--cm-toolbar-background: #000000;
		}

		/* CodeMirror's baseTheme draws a focus outline on `.cm-editor.cm-focused`
		   and a default background on `.cm-panels`/`.cm-panel`. Suppress both. */
		#editor-mount :global(.cm-editor.cm-focused) {
			outline: none;
		}
		#editor-mount :global(.cm-panels),
		#editor-mount :global(.cm-panel) {
			background: transparent;
		}

		#editor-mount :global(.cm-lineNumbers .cm-gutterElement) {
			padding: 0 3px 0 0px;
		}

		/* Override markdown-editor CSS variables for transparent surfaces.
		   Inline `<code>` keeps a white background (see rule below).
		   Bumping the base font-size scales every typographic var (text-base,
		   text-lg, … text-4xl) since they're all derived from this one. */
		#editor-mount :global(.ezco-mde[data-theme="dark"]),
		#editor-mount :global([data-theme="dark"] .ezco-mde) {
			--ezco-mde-bg: transparent;
			--ezco-mde-code-bg: #ffffff;
			--ezco-mde-table-bg: transparent;
			--ezco-mde-base-font-size: 1.25rem;
			/* Embedded codeblocks inherit this for monospace text sizing. */
			--cm-font-size: 1.25rem;
		}

		#editor-mount :global(.ezco-mde li:not(.cm-search-result)::marker) {
			font-size: var(--ezco-mde-text-base);
		}

		/* Inline `<code>`: dark text on the white background set above. */
		#editor-mount :global(.ezco-mde > :not(.cm-editor) code) {
			color: #1e1e1e;
			border-radius: 0px;
		}

		/* Tables: white horizontal rules between rows, no vertical rules,
		   and flush-left first column so its text aligns with the editor's
		   left edge. The package uses `border-collapse: collapse` already,
		   so per-row `border-bottom` works. */
		#editor-mount :global(.ezco-mde table) {
			border: none;
		}
		#editor-mount :global(.ezco-mde tr) {
			border-bottom: 1px solid var(--ezco-mde-code-bg-dark);
		}
		#editor-mount :global(.ezco-mde tr:last-child) {
			border-bottom: none;
		}
		#editor-mount :global(.ezco-mde th:first-child),
		#editor-mount :global(.ezco-mde td:first-child) {
			padding-left: 0;
		}

		/* Tooltips and the search-results dropdown render inside the
		   `.cm-editor`, so a scoped descendant selector is enough. They
		   read `--cm-toolbar-background` (transparent here), so override
		   the background directly. */
		#editor-mount :global(.cm-tooltip),
		#editor-mount :global(.cm-search-results) {
			background: #000000;
		}

		/* The right-click context menu is appended to `document.body`,
		   outside `#editor-mount`, so it needs a fully-global selector.
		   It copies `data-theme` from the editor onto itself. */
		:global(.cm-context-menu[data-theme="dark"]) {
			background: #000000;
		}

		.demo-container {
			width: 100%;
			min-height: 70vh;
			display: flex;
			flex-direction: column;
			background-color: transparent;
			border: none;
		}

		#editor-mount {
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		/* `view-transition-name` is NOT set in CSS because that would
		   apply on both entry and exit. On entry the captured group's
		   bounding box gets interpolated by the UA against a missing
		   counterpart on the previous page, which produces a vertical
		   squeeze. Instead, the name is toggled on inline only when
		   leaving this page (see Layout.astro's `astro:before-preparation`
		   handler) so the OLD snapshot is captured as a named group for
		   the slide-down exit, while the NEW page has no separate group
		   and slides in with the rest of the root. */

		#editor-mount :global(.ezco-mde) {
			flex: 1;
			display: flex;
			flex-direction: column;
		}

		#editor-mount :global(.ProseMirror) {
			flex: 1;
		}

		/* Embedded codeblocks and tables get a slightly wider top
		   margin than the package default (1.5em → 1rem) to feel
		   more inset on the dark demo surface. Top-only — bottom
		   margins are owned by the *next* block's `margin-top`. */
		#editor-mount :global(.cm-editor),
		#editor-mount :global(table) {
			margin-top: 1rem;
			margin-bottom: 0;
		}

		.loading-indicator {
			display: flex;
			align-items: center;
			justify-content: center;
			flex: 1;
			min-height: 200px;
		}

		.loading-bar {
			width: 48px;
			height: 2px;
			background: #444;
			border-radius: 1px;
			animation: loading-pulse 1.5s ease-in-out infinite;
		}

		@keyframes loading-pulse {
			0%, 100% { opacity: 0.3; }
			50% { opacity: 1; }
		}
	</style>
</DualColumnLayout>

{
  "name": "@joinezco/markdown-editor",
  "private": false,
  "version": "0.0.5",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.lib.json",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:browser": "vitest --browser.enabled",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "dependencies": {
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.7",
    "@joinezco/codeblock": "workspace:*",
    "@tiptap/core": "^3.4.1",
    "@tiptap/extension-link": "^3.4.1",
    "@tiptap/extension-table": "^3.4.1",
    "@tiptap/extension-task-item": "^3.4.1",
    "@tiptap/extension-task-list": "^3.4.1",
    "@tiptap/pm": "^3.4.1",
    "@tiptap/react": "^3.4.1",
    "@tiptap/starter-kit": "^3.4.1",
    "multimatch": "^8.0.0",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "style-mod": "^4.1.2",
    "tippy.js": "^6.3.7",
    "tiptap-markdown": "^0.9.0",
    "vite-plugin-node-polyfills": "^0.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/tippy.js": "^6.3.0",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "jsdom": "^29.0.1",
    "micromatch": "^4.0.8",
    "playwright": "^1.49.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.26.1",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "webdriverio": "^9.2.9"

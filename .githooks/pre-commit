#!/usr/bin/env bash
#
# Pre-commit hook: runs cargo fmt --check and clippy on staged Rust files.
# Only runs if Rust files are part of the commit.
#
# Setup (run once after cloning):
#   git config core.hooksPath .githooks
#
# To skip temporarily:
#   git commit --no-verify

set -e

# Check if any Rust files are staged
if ! git diff --cached --name-only --diff-filter=ACMR | grep -q '\.rs$\|Cargo\.toml$\|Cargo\.lock$'; then
    exit 0
fi

echo "pre-commit: checking Rust formatting..."
if ! cargo fmt --all --check; then
    echo ""
    echo "  Run 'cargo fmt --all' to fix."
    exit 1
fi

echo "pre-commit: running clippy..."
if ! cargo clippy --workspace --all-targets -- -D warnings; then
    echo ""
    echo "  Fix clippy warnings before committing."
    exit 1
fi

echo "pre-commit: checks passed."
